MINICODE_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
MINICODE_DEEPSEEK_URL=https://api.deepseek.com
MINICODE_LLM_TIMEOUT=120
MINICODE_MAX_TOKENS=4096
MINICODE_WORKSPACE=.
MINICODE_DOCKER_IMAGE=python:3.12-slim
MINICODE_MAX_STEPS=8
MINICODE_APPROVAL=never
MINICODE_RUN_LOG=.minicode/runs
MINICODE_FINAL_TEST_COMMAND=
MINICODE_EVAL_OUTPUT=.minicode/eval-report.json
MINICODE_SKILLS_DIR=.skills
MINICODE_MAX_SKILLS=2
MINICODE_SKILL_RECALL_K=8
MINICODE_CONTEXT_ARTIFACT_DIR=.minicode/context-artifacts
MINICODE_OBSERVATION_INLINE_LIMIT=6000
MINICODE_OBSERVATION_PREVIEW_CHARS=1200
MINICODE_CONTEXT_HISTORY_CHAR_LIMIT=24000
MINICODE_CONTEXT_KEEP_RECENT_MESSAGES=6
MINICODE_CONTEXT_NOTE_CHAR_LIMIT=6000
MINICODE_MEMORY_DIR=.minicode/memory
MINICODE_MEMORY_TRIGGER=draft
MINICODE_MEMORY_MIN_CONFIDENCE=0.7
MINICODE_MEMORY_MAX_CANDIDATES=5
